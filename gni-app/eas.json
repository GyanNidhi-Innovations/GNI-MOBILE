{
  "cli": {
    "version": ">= 18.7.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk",
        "applicationArchivePath": "android/app/build/outputs/apk/release/*.apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://demos.gyannidhi.in/gni-mobile-api"
      }
    },
    "preview": {
      "environment": "preview",
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://demos.gyannidhi.in/gni-mobile-api"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://demos.gyannidhi.in/gni-mobile-api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}